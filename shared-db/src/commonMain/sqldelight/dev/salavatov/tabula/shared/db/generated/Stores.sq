getAllStores:
SELECT * FROM Accounts;

getActualStores:
SELECT * FROM Accounts WHERE archived == 0;

getStore:
SELECT * FROM Accounts WHERE id = ?;

createStore:
INSERT INTO Accounts(name, in_possession) VALUES (?, ?);

updateStore:
UPDATE Accounts
SET name = :name, in_possession = :in_possession, archived = :archived
WHERE id = :id;
